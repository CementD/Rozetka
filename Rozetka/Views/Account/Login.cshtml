@model Rozetka.ViewModels.LoginViewModel

<div class="login-page">

    <div class="login-card">

        <div class="login-header">
            <h2>Вхід до акаунту</h2>
            <p>Увійдіть, щоб оформлювати замовлення</p>
        </div>

        <form asp-action="Login" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="input-group">
                <label>Email</label>
                <input asp-for="Email" class="form-input" placeholder="Введіть email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="input-group">
                <label>Пароль</label>
                <input asp-for="Password" type="password" class="form-input" placeholder="Введіть пароль" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="login-btn">
                Увійти
            </button>

        </form>

        <div class="login-footer">
            Немає акаунту?
            <a asp-action="Register">Зареєструватися</a>
        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}