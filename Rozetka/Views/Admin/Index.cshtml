@model IEnumerable<Domain.Product>

<div class="admin-layout">

    <aside class="admin-sidebar">

        <div class="admin-logo">
            ROZETKA ADMIN
        </div>

        <ul>
            <li>📦 Товари</li>
            <li>🛒 Замовлення</li>
            <li>👤 Користувачі</li>
            <li>📊 Статистика</li>
        </ul>

    </aside>

    <main class="admin-content">

        <div class="dashboard-header">
            <h1>Панель адміністратора</h1>

            <a asp-action="AddProduct"
               class="add-btn">
                + Додати товар
            </a>
        </div>

        <div class="stats">

            <div class="stat-card">
                <h3>Товари</h3>
                <p>@Model.Count()</p>
            </div>

            <div class="stat-card">
                <h3>Замовлення</h3>
                <p>0</p>
            </div>

            <div class="stat-card">
                <h3>Користувачі</h3>
                <p>0</p>
            </div>

        </div>

        <div class="table-wrapper">

            <table class="admin-table">

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Зображення</th>
                        <th>Назва</th>
                        <th>Ціна</th>
                        <th>Опис</th>
                        <th>Дії</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>

                            <td>
                                <img src="@item.ImageUrl"
                                     class="product-img" />
                            </td>

                            <td>@item.Name</td>

                            <td>@item.Price ₴</td>

                            <td>@item.Description</td>

                            <td class="actions">

                                <a asp-action="EditProduct"
                                   asp-route-id="@item.Id"
                                   class="edit-btn">
                                    Редагувати
                                </a>

                                <form asp-action="DeleteProduct"
                                      method="post"
                                      style="display:inline;">

                                    <input type="hidden"
                                           name="id"
                                           value="@item.Id" />

                                    <button type="submit"
                                            class="delete-btn">
                                        Видалити
                                    </button>

                                </form>

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </main>

</div>