@model Domain.Product

<div class="form-page">
    <div class="form-card">

        <h2>Додати товар</h2>

        <form asp-action="AddProduct" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name">Назва товару</label>
                <input asp-for="Name" class="form-input" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description">Опис</label>
                <textarea asp-for="Description" class="form-input"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Price">Ціна</label>
                <input asp-for="Price" type="number" step="0.01" class="form-input" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ImageUrl">URL картинки</label>
                <input asp-for="ImageUrl" class="form-input" value="/images/laptop.png" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>

            <button type="submit" class="save-btn">
                Зберегти
            </button>

            <a asp-action="Index" class="cancel-btn">
                Назад
            </a>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}