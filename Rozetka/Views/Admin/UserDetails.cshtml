@model Rozetka.ViewModels.Admin.UserDetailsVM

<h1>@Model.FullName</h1>

<p>Email: @Model.Email</p>

<p>Телефон: @Model.PhoneNumber</p>

<p>Адреса: @Model.Address</p>

<h3>Замовлення</h3>

<table class="admin-table">

    <thead>
        <tr>
            <th>ID</th>
            <th>Дата</th>
            <th>Статус</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var order in Model.Orders)
        {
            <tr>

                <td>
                    <a asp-action="OrderDetails"
                       asp-route-id="@order.Id">
                        #@order.Id
                    </a>
                </td>

                <td>@order.OrderDate.ToShortDateString()</td>

                <td>@order.Status</td>

            </tr>
        }

    </tbody>

</table>