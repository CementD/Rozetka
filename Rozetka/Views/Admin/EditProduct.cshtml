@model Rozetka.ViewModels.Admin.ProductEditVM

<div class="form-page">
    <div class="form-card">

        <h2>Редагувати товар</h2>

        <form asp-action="EditProduct" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-input" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" class="form-input"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Price"></label>
                <input asp-for="Price" type="number" step="0.01" class="form-input" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ImageUrl"></label>
                <input asp-for="ImageUrl" class="form-input" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Specifications"></label>
                <textarea asp-for="Specifications" class="form-input"></textarea>
            </div>

            <div class="form-group">
                <label asp-for="CategoryId">Категорія</label>

                <select asp-for="CategoryId"
                        asp-items="Model.Categories"
                        class="form-input">
                </select>

                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <button type="submit" class="save-btn">
                Зберегти
            </button>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}