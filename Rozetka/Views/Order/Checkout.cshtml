@model Rozetka.ViewModels.CheckoutVM
@{
    ViewData["Title"] = "Оформлення замовлення";
}

@await Html.PartialAsync("_Header")

<div class="page-layout">

    <div class="page-header">
        <div>
            <h1><i class="fa-solid fa-credit-card"></i> Оформлення замовлення</h1>
            <p class="page-sub">Крок 2 з 2 — Введіть платіжні дані</p>
        </div>
        <a asp-controller="Cart" asp-action="Index" class="cancel-btn">
            <i class="fa-solid fa-arrow-left"></i> Назад до кошика
        </a>
    </div>

    <div class="checkout-layout">

        <div class="checkout-form-wrap">

            <form asp-action="Checkout" method="post" id="checkout-form">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger admin-validation"></div>

                <div class="checkout-section">
                    <h2 class="checkout-section-title">
                        <i class="fa-solid fa-credit-card"></i> Платіжна картка
                    </h2>

                    <div class="card-preview" id="card-preview">
                        <div class="card-preview-chip"><i class="fa-solid fa-microchip"></i></div>
                        <div class="card-preview-number" id="preview-number">•••• •••• •••• ••••</div>
                        <div class="card-preview-bottom">
                            <span id="preview-expiry">MM/YY</span>
                            <span class="card-preview-brand"><i class="fa-brands fa-cc-visa"></i></span>
                        </div>
                    </div>

                    <div class="form-group" style="margin-top:24px">
                        <label asp-for="CardNumber">
                            <i class="fa-solid fa-credit-card"></i> Номер картки
                        </label>
                        <input asp-for="CardNumber" class="form-input" id="card-number-input"
                               placeholder="0000 0000 0000 0000" maxlength="19"
                               oninput="formatCardNumber(this)" autocomplete="cc-number" />
                        <span asp-validation-for="CardNumber" class="text-danger"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="CardExpiry">
                                <i class="fa-regular fa-calendar"></i> Термін дії
                            </label>
                            <input asp-for="CardExpiry" class="form-input" id="card-expiry-input"
                                   placeholder="MM/YY" maxlength="5"
                                   oninput="formatExpiry(this)" autocomplete="cc-exp" />
                            <span asp-validation-for="CardExpiry" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="CardCvv">
                                <i class="fa-solid fa-lock"></i> CVV
                            </label>
                            <input asp-for="CardCvv" class="form-input" type="password"
                                   placeholder="•••" maxlength="3" autocomplete="cc-csc" />
                            <span asp-validation-for="CardCvv" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <button type="submit" class="order-btn" style="margin-top:8px">
                    <i class="fa-solid fa-check"></i> Підтвердити та оплатити
                </button>

            </form>
        </div>

        <div class="cart-summary">
            <h2 class="cart-summary-title">
                <i class="fa-solid fa-receipt"></i> Ваше замовлення
            </h2>

            <div id="checkout-summary-items">
                <div class="checkout-loading">
                    <i class="fa-solid fa-spinner fa-spin"></i> Завантаження...
                </div>
            </div>

            <div class="cart-summary-row" style="margin-top:12px">
                <span>Доставка</span>
                <span class="text-success">Безкоштовно</span>
            </div>

            <div class="cart-summary-total" id="checkout-total">
                <span>До сплати</span>
                <span class="td-price">—</span>
            </div>

            <div class="checkout-secure">
                <i class="fa-solid fa-shield-halved"></i>
                Захищена оплата через SSL
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function formatCardNumber(input) {
            let val = input.value.replace(/\D/g, '').substring(0, 16);
            input.value = val.replace(/(.{4})/g, '$1 ').trim();
            document.getElementById('preview-number').textContent =
                val.padEnd(16, '•').replace(/(.{4})/g, '$1 ').trim();

            const brand = document.querySelector('.card-preview-brand i');
            if (val.startsWith('4')) brand.className = 'fa-brands fa-cc-visa';
            else if (val.startsWith('5')) brand.className = 'fa-brands fa-cc-mastercard';
            else brand.className = 'fa-brands fa-cc-visa';
        }

        function formatExpiry(input) {
            let val = input.value.replace(/\D/g, '').substring(0, 4);
            if (val.length >= 2) val = val.substring(0, 2) + '/' + val.substring(2);
            input.value = val;
            document.getElementById('preview-expiry').textContent = val || 'MM/YY';
        }

        async function loadCartSummary() {
            try {
                const resp = await fetch('/Cart/SummaryJson');
                if (!resp.ok) return;
                const cart = await resp.json();

                const container = document.getElementById('checkout-summary-items');
                const totalEl   = document.getElementById('checkout-total').querySelector('.td-price');

                if (!cart.items || cart.items.length === 0) {
                    container.innerHTML = '<p style="color:#9ca3af;text-align:center;padding:16px">Кошик порожній</p>';
                    return;
                }

                container.innerHTML = cart.items.map(item => `
                    <div class="checkout-item">
                        <img src="${item.productImageUrl || '/images/phone.jpg'}"
                             onerror="this.src='/images/phone.jpg'" />
                        <div class="checkout-item-info">
                            <span class="checkout-item-name">${item.productName}</span>
                            <span class="checkout-item-qty">× ${item.quantity}</span>
                        </div>
                        <span class="checkout-item-price">${item.totalPrice.toLocaleString('uk-UA')} ₴</span>
                    </div>
                `).join('');

                totalEl.textContent = cart.cartTotal.toLocaleString('uk-UA') + ' ₴';
            } catch (e) {
                console.error('Cart load error:', e);
            }
        }

        loadCartSummary();
    </script>
}
