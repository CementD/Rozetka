@model Rozetka.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "ROZETKA";
    var topProducts = Model.Products?.Take(8).ToList() ?? new List<BLL.DTOs.ProductReadDto>();
    var categories = Model.Categories?.ToList() ?? new List<BLL.DTOs.CategoryReadDto>();
}

@await Html.PartialAsync("_Header")

<section class="main-layout">
    <aside class="category-panel">
        <h3>Категорії</h3>
        @if (categories.Any())
        {
            @foreach (var cat in categories)
            {
                <a asp-controller="Product" asp-action="Index" asp-route-category="@cat.Name">
                    <i class="fa-solid fa-tag"></i> @cat.Name
                </a>
            }
        }
        else
        {
            <a asp-controller="Product" asp-action="Index" asp-route-category="Ноутбуки"><i class="fa-solid fa-laptop"></i> Ноутбуки</a>
            <a asp-controller="Product" asp-action="Index" asp-route-category="Смартфони"><i class="fa-solid fa-mobile-screen-button"></i> Смартфони</a>
            <a asp-controller="Product" asp-action="Index" asp-route-category="Телевізори"><i class="fa-solid fa-tv"></i> Телевізори</a>
            <a asp-controller="Product" asp-action="Index" asp-route-category="Навушники"><i class="fa-solid fa-headphones"></i> Навушники</a>
        }
        <a asp-controller="Product" asp-action="Index" style="border-top:1px solid #eee;margin-top:8px;padding-top:12px">
            <i class="fa-solid fa-grip"></i> Всі категорії
        </a>
    </aside>

    <main class="home-content">
        <div class="banner">
            <div class="banner-content">
                <div class="banner-badge"><i class="fa-solid fa-fire"></i> Гарячі пропозиції</div>
                <h1>Великий розпродаж техніки</h1>
                <p>Знижки до 40% на популярні товари</p>
                <a asp-controller="Product" asp-action="Index" class="banner-btn">
                    Перейти до каталогу <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>
        </div>

        <div class="section-header">
            <h2>Популярні товари</h2>
            <a asp-controller="Product" asp-action="Index" class="see-all-link">
                Дивитись всі <i class="fa-solid fa-chevron-right"></i>
            </a>
        </div>

        @if (topProducts.Any())
        {
            <div class="products-grid">
                @foreach (var product in topProducts)
                {
                    <a asp-controller="Product" asp-action="Details"
                       asp-route-id="@product.Id" class="home-product-card">
                        <div class="card-img-wrap">
                            <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/phone.jpg" : product.ImageUrl)"
                                 alt="@product.Name" onerror="this.src='/images/phone.jpg'" />
                        </div>
                        <h3>@product.Name</h3>
                        @if (!string.IsNullOrEmpty(product.Description))
                        {
                            <p class="desc">@(product.Description.Length > 60 ? product.Description[..60] + "…" : product.Description)</p>
                        }
                        <p class="price">@product.Price.ToString("N0") <span class="currency">₴</span></p>
                        <div class="card-actions">
                            <form asp-controller="Cart" asp-action="AddToCart" method="post"
                                  onclick="event.stopPropagation()">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@product.Id" />
                                <button type="submit" class="buy-btn">
                                    <i class="fa-solid fa-cart-plus"></i> Купити
                                </button>
                            </form>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa-solid fa-box-open empty-icon"></i>
                <h2>Товарів ще немає</h2>
                <p>Скоро тут з'являться товари</p>
            </div>
        }

        @if (categories.Any())
        {
            <div class="promo-grid">
                @{
                    var promoClasses = new[] { "promo-blue", "promo-dark", "promo-green" }; int pi = 0;
                }
                @foreach (var cat in categories.Take(3))
                {
                    <div class="promo-card @promoClasses[pi % 3]">
                        <i class="fa-solid fa-tag promo-icon"></i>
                        <h3>@cat.Name</h3>
                        <p>Найкращі пропозиції</p>
                        <a asp-controller="Product" asp-action="Index" asp-route-category="@cat.Name">
                            Обрати <i class="fa-solid fa-arrow-right"></i>
                        </a>
                    </div>
                    pi++;
                }
            </div>
        }
    </main>
</section>
