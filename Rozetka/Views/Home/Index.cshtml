@{
    ViewData["Title"] = "ROZETKA";
}

<header class="hero-header">
    <div class="hero-logo">ROZETKA</div>

    <button class="catalog-btn">☰ Каталог</button>

    <div class="hero-search">
        <input type="text" placeholder="Я шукаю..." />
        <button>Знайти</button>
    </div>

    <div class="hero-icons">
        <a asp-controller="Account" asp-action="Login">👤</a>
        <a href="#">❤</a>
        <a href="#">🛒</a>
    </div>
</header>

<section class="main-layout">
    <aside class="category-panel">
        <h3>Категорії</h3>
        <a>💻 Ноутбуки</a>
        <a>📱 Смартфони</a>
        <a>📺 Телевізори</a>
        <a>🎧 Навушники</a>
        <a>🏠 Побутова техніка</a>
    </aside>

    <main class="home-content">
        <div class="banner">
            <div>
                <h1>Великий розпродаж техніки</h1>
                <p>Знижки до 40% на популярні товари</p>
                <a asp-controller="Product" asp-action="Index">Перейти до каталогу</a>
            </div>
        </div>

        <h2>Популярні товари</h2>

        <div class="products-grid">
            <div class="home-product-card">
                <span class="badge">Топ продажів</span>
                <img src="/images/laptop.jpg" alt="Laptop" />
                <h3>Lenovo IdeaPad</h3>
                <p class="desc">15.6 Full HD / Ryzen 5 / 16GB RAM</p>
                <p class="price">24 999 ₴</p>
                <button>Купити</button>
            </div>

            <div class="home-product-card">
                <span class="badge">Новинка</span>
                <img src="/images/phone.jpg" alt="Phone" />
                <h3>Samsung Galaxy S26</h3>
                <p class="desc">AMOLED / 128GB / NFC</p>
                <p class="price">16 499 ₴</p>
                <button>Купити</button>
            </div>
        </div>
    </main>
</section>