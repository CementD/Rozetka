@model Domain.Cart
@{
    ViewData["Title"] = "Кошик";
    var items = Model?.Items ?? new List<Domain.CartItem>();
    var total = items.Sum(i => i.Product?.Price * i.Quantity ?? 0);
}

@await Html.PartialAsync("_Header")

<div class="page-layout">
    <div class="page-header">
        <h1><i class="fa-solid fa-cart-shopping"></i> Кошик</h1>
        <a asp-controller="Product" asp-action="Index" class="cancel-btn">
            <i class="fa-solid fa-arrow-left"></i> Продовжити покупки
        </a>
    </div>

    @if (!items.Any())
    {
        <div class="empty-state">
            <i class="fa-solid fa-cart-shopping empty-icon"></i>
            <h2>Кошик порожній</h2>
            <p>Додайте товари щоб оформити замовлення</p>
            <a asp-controller="Product" asp-action="Index" class="buy-btn" style="display:inline-flex;padding:14px 28px">
                <i class="fa-solid fa-store"></i>&nbsp; До каталогу
            </a>
        </div>
    }
    else
    {
        <div class="cart-layout">

            <div class="cart-items">
                @foreach (var item in items)
                {
                    <div class="cart-item">
                        <div class="cart-item-img">
                            <img src="@(string.IsNullOrEmpty(item.Product?.ImageUrl) ? "/images/phone.jpg" : item.Product.ImageUrl)"
                                 alt="@item.Product?.Name" onerror="this.src='/images/phone.jpg'" />
                        </div>
                        <div class="cart-item-info">
                            <h3 class="cart-item-name">@item.Product?.Name</h3>
                            @if (!string.IsNullOrEmpty(item.Product?.Description))
                            {
                                <p class="cart-item-desc">@(item.Product.Description.Length > 80 ? item.Product.Description[..80] + "…" : item.Product.Description)</p>
                            }
                            <div class="cart-item-meta">
                                <span class="cart-item-price">@item.Product?.Price.ToString("N0") ₴ / шт.</span>
                            </div>
                        </div>
                        <div class="cart-item-total">
                            <span class="td-price">@((item.Product?.Price * item.Quantity)?.ToString("N0")) ₴</span>
                            <div class="qty-control">
                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <input type="hidden" name="delta" value="-1" />
                                    <button type="submit" class="qty-btn" title="Зменшити">
                                        <i class="fa-solid fa-minus"></i>
                                    </button>
                                </form>
                                <span class="qty-value">@item.Quantity</span>
                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <input type="hidden" name="delta" value="1" />
                                    <button type="submit" class="qty-btn" title="Збільшити">
                                        <i class="fa-solid fa-plus"></i>
                                    </button>
                                </form>
                            </div>
                            <form asp-controller="Cart" asp-action="RemoveItem" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                <button type="submit" class="cart-remove-btn" title="Видалити"
                                        onclick="return confirm('Видалити товар з кошика?')">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }

                <div class="cart-footer-actions">
                    <form asp-controller="Cart" asp-action="ClearCart" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="cart-clear-btn"
                                onclick="return confirm('Очистити весь кошик?')">
                            <i class="fa-solid fa-trash"></i> Очистити кошик
                        </button>
                    </form>
                </div>
            </div>

            <div class="cart-summary">
                <h2 class="cart-summary-title"><i class="fa-solid fa-receipt"></i> Підсумок</h2>

                <div class="cart-summary-row">
                    <span>Товарів</span>
                    <span>@items.Sum(i => i.Quantity) шт.</span>
                </div>
                <div class="cart-summary-row">
                    <span>Доставка</span>
                    <span class="text-success">Безкоштовно</span>
                </div>
                <div class="cart-summary-total">
                    <span>До сплати</span>
                    <span class="td-price">@total.ToString("N0") ₴</span>
                </div>

                <form asp-controller="Order" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="order-btn">
                        <i class="fa-solid fa-check"></i> Оформити замовлення
                    </button>
                </form>

                <a asp-controller="Product" asp-action="Index" class="cart-continue-link">
                    <i class="fa-solid fa-arrow-left"></i> Продовжити покупки
                </a>
            </div>

        </div>
    }
</div>
